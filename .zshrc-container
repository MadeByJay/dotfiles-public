# Container zshrc — optimized for devcontainer environment
# No homebrew, no NVM, no pyenv — container manages its own tooling

# ── History ──────────────────────────────────────────────────────────────────
HISTSIZE=50000
SAVEHIST=50000
HISTFILE="$HOME/.zsh_history"
setopt HIST_IGNORE_DUPS
setopt HIST_IGNORE_ALL_DUPS
setopt HIST_FIND_NO_DUPS
setopt HIST_IGNORE_SPACE
setopt SHARE_HISTORY
setopt APPEND_HISTORY

# ── Environment ───────────────────────────────────────────────────────────────
export EDITOR="nvim"
export LANG="en_US.UTF-8"
export PATH="$HOME/.local/bin:/usr/local/bin:$PATH"

# pyenv (container-local, under jenkins user)
export PYENV_ROOT="/var/lib/jenkins/.pyenv"
export PATH="$PYENV_ROOT/bin:$PYENV_ROOT/shims:$PATH"

# ── Aliases ───────────────────────────────────────────────────────────────────
alias ll='ls -lhF --color=auto'
alias la='ls -lAhF --color=auto'
alias l='ls -CF --color=auto'
alias ..='cd ..'
alias ...='cd ../..'
alias grep='grep --color=auto'
alias reload='source ~/.zshrc'

# Git
alias gs='git status'
alias gd='git diff'
alias gl='git log --oneline --graph --decorate'

# npm
alias nr='npm run'

# fzf
alias f='fzf'

# Navigation
alias repos='cd ~/repos'
alias adl='cd ~/ad-filtering'

# Python / uv
alias py='python'
alias uvr='uv run'

# Docker
alias dps='docker ps'
alias dcp='docker compose'
alias dcup='docker compose up -d'
alias dcdn='docker compose down'

# ── Prompt ────────────────────────────────────────────────────────────────────
eval "$(starship init zsh)"
